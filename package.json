{
  "name": "courses",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "scrape",
    "app",
    "db"
  ],
  "scripts": {
    "dev": "bun --filter @courses/app dev",
    "build": "turbo run build",
    "preview": "bun --filter @courses/app preview",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "turbo run lint format:check typecheck",
    "fix": "turbo run lint:fix format",
    "git:safe:commit": "lint-staged",
    "git:safe:push": "turbo run lint typecheck build",
    "scrape:evals": "bun --filter @courses/scrape run scrape:evals",
    "scrape:courses": "bun --filter @courses/scrape run scrape:courses",
    "generate-embeddings": "bun --filter @courses/scrape run generate-embeddings",
    "generate-embeddings:force": "bun --filter @courses/scrape run generate-embeddings -- --force",
    "db:migrate": "psql $DATABASE_URL -f db/migrations/001_add_vector_embeddings.sql",
    "db:migrate:down": "psql $DATABASE_URL -f db/migrations/001_add_vector_embeddings_down.sql",
    "db:generate-types": "bun --filter @courses/db run codegen",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/eslint-plugin-router": "^1.161.4",
    "@types/node": "^25.4.0",
    "@typescript/native-preview": "^7.0.0-dev.20260309.1",
    "add": "^2.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "router": "^2.2.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "oxlint --type-aware --fix --import-plugin --max-warnings=0",
    "*.{ts,tsx,js,jsx,json,css,md}": "oxfmt"
  },
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
